NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Server-only Supabase secret key (sb_secret_...). Never expose it with a NEXT_PUBLIC_ prefix.
SUPABASE_SECRET_KEY=
# Keep false for manual mode. Set true only after the official API is configured.
NEXT_PUBLIC_CLASH_API_ENABLED=false
# Public screenshot-import rollout and compatibility controls (no secrets).
NEXT_PUBLIC_SCREENSHOT_IMPORT_ENABLED=true
NEXT_PUBLIC_LABORATORY_IMPORT_ENABLED=true
NEXT_PUBLIC_VILLAGE_DETECTION_ENABLED=true
NEXT_PUBLIC_SUPPORTED_GAME_UI_VERSION=coc-ui-2026-07
NEXT_PUBLIC_SCREENSHOT_MODEL_VERSION=local-tesseract-v1
NEXT_PUBLIC_SCREENSHOT_LAYOUT_VERSION=guided-layout-v1
# Comma-separated views verified for the current game/model/layout release.
NEXT_PUBLIC_SCREENSHOT_SUPPORTED_TYPES=laboratory,heroes,pets,equipment,builders,buildings,walls,village,resources,profile
# Server-side automatic deletion deadlines (1-365 days).
SCREENSHOT_RETAINED_ORIGINAL_DAYS=30
SCREENSHOT_UNFINISHED_IMPORT_DAYS=7
CLASH_OF_CLANS_API_TOKEN=
# Optional proxy for serverless hosts without a fixed outbound IP.
CLASH_OF_CLANS_API_PROXY_URL=
CLASH_OF_CLANS_API_PROXY_SECRET=
NEXT_PUBLIC_WEB_PUSH_VAPID_PUBLIC_KEY=
WEB_PUSH_VAPID_PRIVATE_KEY=
WEB_PUSH_VAPID_SUBJECT=mailto:admin@example.com
CRON_SECRET=
DISCORD_PUBLIC_KEY=
DISCORD_APPLICATION_ID=
DISCORD_BOT_TOKEN=
# Optional: registers commands instantly in one test server instead of globally.
DISCORD_GUILD_ID=
