NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Server-only Supabase secret key (sb_secret_...). Never expose it with a NEXT_PUBLIC_ prefix.
SUPABASE_SECRET_KEY=
# Keep false for manual mode. Set true only after the official API is configured.
NEXT_PUBLIC_CLASH_API_ENABLED=false
CLASH_OF_CLANS_API_TOKEN=
# Optional proxy for serverless hosts without a fixed outbound IP.
CLASH_OF_CLANS_API_PROXY_URL=
CLASH_OF_CLANS_API_PROXY_SECRET=
NEXT_PUBLIC_WEB_PUSH_VAPID_PUBLIC_KEY=
WEB_PUSH_VAPID_PRIVATE_KEY=
WEB_PUSH_VAPID_SUBJECT=mailto:admin@example.com
CRON_SECRET=
DISCORD_PUBLIC_KEY=
DISCORD_APPLICATION_ID=
DISCORD_BOT_TOKEN=
# Optional: registers commands instantly in one test server instead of globally.
DISCORD_GUILD_ID=
